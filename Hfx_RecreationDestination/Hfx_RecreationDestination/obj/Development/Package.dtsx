                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    LTRIM(RTRIM(st.[Asset Code]))    AS [Asset Code],
    MIN(LTRIM(RTRIM(st.[Asset ID]))) AS [Asset ID]  
FROM stg.Recdestination st
WHERE st.[Asset Code] IS NOT NULL
  AND LTRIM(RTRIM(st.[Asset Code])) &lt;&gt; ''
GROUP BY
    LTRIM(RTRIM(st.[Asset Code]));</property>
