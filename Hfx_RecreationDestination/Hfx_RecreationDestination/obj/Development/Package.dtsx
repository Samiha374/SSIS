                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    LTRIM(RTRIM(a.[Asset ID]))           AS [Asset ID],
    LTRIM(RTRIM(a.[Asset Code]))         AS [Asset Code],
    st.[Owner],
    st.[Install Year],
    st.[Material],
    st.[Material Confidence],
    st.[General Location],
    st.[Land ID],
    st.[Recreation Poly ID],
    st.[Install Date],
    st.[Maintained By],
    st.[Add Date],
    st.[Modified Date],
    st.[Source Date]
FROM [Hfx_Recreation].[stg].[RecDestination] AS st
LEFT JOIN [Hfx_Recreation].[lup].[Asset]     AS a
       ON
       LTRIM(RTRIM(a.[Asset Code])) = LTRIM(RTRIM(st.[Asset Code]))
WHERE a.[Asset ID] IS NOT NULL  -- only load rows that matched the lookup
  AND st.[Asset ID]   IS NOT NULL AND LTRIM(RTRIM(st.[Asset ID]))   &lt;&gt; ''</property>
